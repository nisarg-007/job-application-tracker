{
    "manifest_version": 3,
    "name": "Job Application Tracker",
    "version": "2.0.0",
    "description": "Track job applications into Google Sheets with one click. Includes dashboard, daily goals, duplicate detection, and follow-up reminders.",
    "author": "Nisarg Shah [Vibe Coder]",
    "homepage_url": "https://github.com/nisarg-shah",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "Track this Job Application"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "alarms"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content_script.js"
            ],
            "run_at": "document_idle"
        }
    ]
}